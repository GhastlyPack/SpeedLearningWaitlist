# Customer.io CDP (Data Pipelines) write key.
# Public — exposed to the browser by design. The default in app/layout.tsx
# already points at the SpeedLearning workspace; only set this if the key
# rotates or you want to override in Preview/Dev.
NEXT_PUBLIC_CIO_WRITE_KEY=

# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX).
# Public — exposed to the browser. Default is baked into app/layout.tsx;
# set this only if you need to override the prod GA property for Preview/Dev.
# Note: dev builds automatically route events to GA4 DebugView via
# debug_mode based on NODE_ENV — no separate env var needed for that.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Meta Pixel ID (a.k.a. Dataset ID).
# Public — exposed to the browser. Default is baked into app/layout.tsx;
# set this only if you need to override the prod pixel for Preview/Dev.
NEXT_PUBLIC_META_PIXEL_ID=

# Meta Conversions API access token.
# SECRET — server-only, NEVER exposed to the browser. Used by
# app/api/meta-capi/route.ts to deduplicate browser pixel events with a
# server-side fallback (resilient against ad blockers + iOS 14+).
# Generate in Events Manager → Settings → Conversions API → Generate Access
# Token. Drop into Vercel → Settings → Environment Variables for Production,
# Preview, and Development.
META_CAPI_TOKEN=

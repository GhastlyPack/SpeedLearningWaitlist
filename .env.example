# Customer.io Track API credentials.
# Server-only, never exposed to the browser. Both required for /api/cio-track
# to write signups directly into the Journeys workspace.
# Find them in Workspace Settings -> API and webhook credentials -> Track API Keys.
CIO_TRACK_SITE_ID=
CIO_TRACK_API_KEY=

# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX).
# Public — exposed to the browser. Default is baked into app/layout.tsx;
# set this only if you need to override the prod GA property for Preview/Dev.
# Note: dev builds automatically route events to GA4 DebugView via
# debug_mode based on NODE_ENV — no separate env var needed for that.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Meta Pixel ID (a.k.a. Dataset ID).
# Public — exposed to the browser. Default is baked into app/layout.tsx;
# set this only if you need to override the prod pixel for Preview/Dev.
NEXT_PUBLIC_META_PIXEL_ID=

# ---------------------------------------------------------------------------
# Internal Dashboard (dash.speedlearning.com)
# ---------------------------------------------------------------------------

# Shared password for HTTP Basic Auth on /dashboard/* routes.
# Server-only, never exposed to browser. Mark Sensitive in Vercel.
DASHBOARD_PASSWORD=

# GA4 numeric Property ID (NOT the G-XXXXXXX Measurement ID). Find in
# GA4 Admin -> Property -> Property details.
GA_PROPERTY_ID=

# Base64-encoded contents of the GCP service account JSON key for GA4 Data
# API. Generate via `base64 < service-account.json`. The service account
# email needs Viewer role on the GA4 property. Mark Sensitive in Vercel.
GOOGLE_APPLICATION_CREDENTIALS_BASE64=

# Customer.io App API key (Bearer token). Read scopes are enough.
# Mark Sensitive in Vercel.
CIO_APP_API_KEY=

# Customer.io workspace region: "us" (default) or "eu".
CIO_REGION=us

# ---------------------------------------------------------------------------

# Meta Conversions API access token.
# SECRET — server-only, NEVER exposed to the browser. Used by
# app/api/meta-capi/route.ts to deduplicate browser pixel events with a
# server-side fallback (resilient against ad blockers + iOS 14+).
# Generate in Events Manager → Settings → Conversions API → Generate Access
# Token. Drop into Vercel → Settings → Environment Variables for Production,
# Preview, and Development.
META_CAPI_TOKEN=
